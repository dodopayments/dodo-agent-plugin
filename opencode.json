{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "@dodopayments/opencode-plugin"
    ],
    "mcp": {
        "dodopayments-api": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "mcp-remote@latest",
                "https://mcp.dodopayments.com/sse"
            ],
            "enabled": true
        },
        "dodo-knowledge": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "mcp-remote@latest",
                "https://knowledge.dodopayments.com/mcp"
            ],
            "enabled": true
        }
    }
}
